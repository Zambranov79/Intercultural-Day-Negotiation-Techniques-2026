<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PepsiCo Ecuador — Reto Logístico</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #070B14;
  --bg2: #0D1526;
  --bg3: #111E35;
  --blue: #004B93;
  --blue2: #0078D7;
  --red: #ED1C24;
  --gold: #F7B731;
  --green: #2ED573;
  --cyan: #48DBFB;
  --white: #F0F4FF;
  --gray: #4A5568;
  --gray2: #2D3748;
  --font-title: 'Barlow Condensed', sans-serif;
  --font-body: 'Inter', sans-serif;
  --font-data: 'JetBrains Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--white);
  font-family: var(--font-body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── INTRO SCREEN ── */
#intro-screen {
  position: fixed; inset: 0; z-index: 1000;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  overflow: hidden;
}

.stars-bg {
  position: absolute; inset: 0; pointer-events: none;
}

.star {
  position: absolute;
  background: var(--white);
  border-radius: 50%;
  animation: twinkle var(--d, 3s) infinite var(--delay, 0s);
}

@keyframes twinkle {
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.4); }
}

.grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,120,215,0.07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,120,215,0.07) 1px, transparent 1px);
  background-size: 48px 48px;
}

.pepsi-globe {
  width: 160px; height: 160px;
  border-radius: 50%;
  background: conic-gradient(
    var(--blue) 0deg 180deg,
    var(--red) 180deg 360deg
  );
  position: relative;
  animation: globeSpin 8s linear infinite, float 3s ease-in-out infinite;
  box-shadow: 0 0 60px rgba(0,120,215,0.5), 0 0 120px rgba(237,28,36,0.2);
  margin-bottom: 40px;
}

.pepsi-globe::before {
  content: '';
  position: absolute;
  left: 50%; top: 40%;
  transform: translate(-50%, -50%);
  width: 100%; height: 22%;
  background: var(--white);
  border-radius: 50%;
  box-shadow: 0 0 20px rgba(255,255,255,0.3);
}

.pepsi-globe::after {
  content: '';
  position: absolute; inset: 8px;
  border-radius: 50%;
  background: rgba(7,11,20,0.15);
  background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.25) 0%, transparent 60%);
}

@keyframes globeSpin {
  from { filter: hue-rotate(0deg); }
  to { filter: hue-rotate(360deg); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16px); }
}

.intro-title {
  font-family: var(--font-title);
  font-size: 72px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  line-height: 1;
  text-align: center;
  background: linear-gradient(135deg, var(--blue2), var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8px;
}

.intro-sub {
  font-family: var(--font-title);
  font-size: 28px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 6px;
  text-transform: uppercase;
  text-align: center;
  margin-bottom: 16px;
}

.intro-desc {
  font-size: 15px;
  color: rgba(240,244,255,0.6);
  text-align: center;
  max-width: 520px;
  line-height: 1.7;
  margin-bottom: 48px;
}

.btn-start {
  font-family: var(--font-title);
  font-size: 22px;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 18px 64px;
  background: linear-gradient(135deg, var(--blue), var(--blue2));
  border: none;
  border-radius: 4px;
  color: var(--white);
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 0 30px rgba(0,120,215,0.4);
}

.btn-start:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 40px rgba(0,120,215,0.6);
}

.btn-start::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.15));
}

/* ── GAME LAYOUT ── */
#game-screen {
  display: none;
  flex-direction: column;
  min-height: 100vh;
}

/* HEADER */
.header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(7,11,20,0.97);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,120,215,0.3);
  padding: 0 24px;
  height: 64px;
  display: flex; align-items: center; gap: 24px;
}

.header-logo {
  font-family: var(--font-title);
  font-size: 22px;
  font-weight: 900;
  letter-spacing: 1px;
}

.header-logo span { color: var(--blue2); }
.header-logo small {
  font-size: 11px;
  font-weight: 400;
  color: rgba(240,244,255,0.5);
  display: block;
  letter-spacing: 2px;
  margin-top: -4px;
}

.header-sep { flex: 1; }

.timer-block {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 20px;
  background: rgba(237,28,36,0.12);
  border: 1px solid rgba(237,28,36,0.4);
  border-radius: 4px;
}

.timer-label {
  font-family: var(--font-data);
  font-size: 11px;
  color: var(--red);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.timer-value {
  font-family: var(--font-data);
  font-size: 26px;
  font-weight: 700;
  color: var(--red);
  animation: blink 1s step-end infinite;
  min-width: 70px;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.timer-value.urgent { color: var(--red); animation: blinkFast 0.4s step-end infinite; }

@keyframes blinkFast {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.1; }
}

.score-block {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 20px;
  background: rgba(247,183,49,0.1);
  border: 1px solid rgba(247,183,49,0.35);
  border-radius: 4px;
}

.score-label {
  font-family: var(--font-data);
  font-size: 11px;
  color: var(--gold);
  letter-spacing: 2px;
}

.score-value {
  font-family: var(--font-data);
  font-size: 26px;
  font-weight: 700;
  color: var(--gold);
  min-width: 56px;
  transition: transform 0.15s;
}

.score-value.bump { animation: scoreBump 0.3s ease; }
@keyframes scoreBump { 0%,100%{transform:scale(1)} 50%{transform:scale(1.25)} }

.btn-submit {
  font-family: var(--font-title);
  font-size: 16px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 10px 28px;
  background: linear-gradient(135deg, var(--green), #1ba354);
  border: none; border-radius: 4px;
  color: #070B14;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.2s;
}

.btn-submit:disabled { opacity: 0.35; cursor: not-allowed; }
.btn-submit:not(:disabled):hover { transform: scale(1.04); }

/* MAIN 3-COLUMN LAYOUT */
.main-grid {
  display: grid;
  grid-template-columns: 300px 1fr 290px;
  gap: 0;
  flex: 1;
  min-height: calc(100vh - 64px);
}

/* LEFT PANEL */
.left-panel {
  background: var(--bg2);
  border-right: 1px solid rgba(0,120,215,0.2);
  overflow-y: auto;
  padding: 16px 12px;
}

.panel-title {
  font-family: var(--font-title);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 3px;
  color: rgba(240,244,255,0.4);
  text-transform: uppercase;
  padding: 0 4px 12px;
  border-bottom: 1px solid rgba(0,120,215,0.2);
  margin-bottom: 12px;
}

/* CITY CARDS */
.city-card {
  background: var(--bg3);
  border: 1px solid rgba(0,120,215,0.15);
  border-radius: 6px;
  margin-bottom: 10px;
  overflow: hidden;
  transition: border-color 0.2s;
}

.city-card.in-route { border-color: var(--gold); }
.city-card.assigned { border-color: var(--green); }
.city-card.conflict { border-color: var(--red); }

.city-header {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px;
  cursor: pointer;
  user-select: none;
}

.city-header:hover { background: rgba(0,120,215,0.08); }

.city-code {
  font-family: var(--font-data);
  font-size: 12px;
  font-weight: 700;
  color: var(--blue2);
  background: rgba(0,120,215,0.15);
  padding: 2px 6px;
  border-radius: 3px;
  min-width: 38px;
  text-align: center;
}

.city-name {
  font-family: var(--font-title);
  font-size: 17px;
  font-weight: 700;
  flex: 1;
}

.city-status-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--gray);
  flex-shrink: 0;
  transition: background 0.3s;
}

.city-card.in-route .city-status-dot { background: var(--gold); }
.city-card.assigned .city-status-dot { background: var(--green); }
.city-card.conflict .city-status-dot { background: var(--red); }

.city-toggle {
  font-size: 12px; color: rgba(240,244,255,0.4);
  transition: transform 0.2s;
}

.city-card.open .city-toggle { transform: rotate(180deg); }

.city-details {
  display: none;
  padding: 0 12px 12px;
  border-top: 1px solid rgba(0,120,215,0.12);
}

.city-card.open .city-details { display: block; }

.city-meta {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 6px; margin: 10px 0;
}

.meta-item {
  background: rgba(0,0,0,0.3);
  border-radius: 4px;
  padding: 6px 8px;
}

.meta-label {
  font-family: var(--font-data);
  font-size: 9px;
  color: rgba(240,244,255,0.4);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 2px;
}

.meta-value {
  font-family: var(--font-data);
  font-size: 13px;
  font-weight: 700;
}

.priority-tag {
  display: inline-block;
  font-family: var(--font-data);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 2px;
  margin-bottom: 8px;
}

.priority-urgent { background: rgba(237,28,36,0.2); color: var(--red); border: 1px solid rgba(237,28,36,0.4); }
.priority-volume { background: rgba(247,183,49,0.2); color: var(--gold); border: 1px solid rgba(247,183,49,0.4); }
.priority-cold { background: rgba(72,219,251,0.2); color: var(--cyan); border: 1px solid rgba(72,219,251,0.4); }
.priority-normal { background: rgba(74,85,104,0.3); color: rgba(240,244,255,0.6); border: 1px solid rgba(74,85,104,0.4); }
.priority-base { background: rgba(0,120,215,0.2); color: var(--blue2); border: 1px solid rgba(0,120,215,0.4); }

/* VEHICLE SELECTOR 2x2 */
.vehicle-label {
  font-family: var(--font-data);
  font-size: 9px;
  color: rgba(240,244,255,0.4);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.vehicle-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}

.vehicle-btn {
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(0,120,215,0.2);
  border-radius: 5px;
  padding: 8px 6px;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}

.vehicle-btn:hover { border-color: var(--blue2); background: rgba(0,120,215,0.1); }

.vehicle-btn.selected {
  border-color: var(--green);
  background: rgba(46,213,115,0.12);
  box-shadow: 0 0 10px rgba(46,213,115,0.2);
}

.vehicle-btn.conflict {
  border-color: var(--red);
  background: rgba(237,28,36,0.1);
}

.vehicle-icon { font-size: 22px; margin-bottom: 3px; }

.vehicle-name {
  font-family: var(--font-data);
  font-size: 9px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.5px;
}

.vehicle-cap {
  font-family: var(--font-data);
  font-size: 8px;
  color: rgba(240,244,255,0.45);
}

/* ROUTE SUMMARY at bottom of left */
.route-summary {
  margin-top: 12px;
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(0,120,215,0.2);
  border-radius: 6px;
  padding: 12px;
}

.route-path {
  font-family: var(--font-data);
  font-size: 12px;
  color: var(--gold);
  word-break: break-all;
  line-height: 1.8;
  min-height: 20px;
}

/* CENTER: MAP */
.center-panel {
  position: relative;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 16px;
  overflow: hidden;
}

.map-title {
  font-family: var(--font-title);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 3px;
  color: rgba(240,244,255,0.35);
  text-transform: uppercase;
  margin-bottom: 12px;
  align-self: flex-start;
}

#ecuador-map {
  width: 100%;
  max-width: 560px;
  height: auto;
}

/* SVG map elements */
.city-marker {
  cursor: pointer;
  transition: all 0.2s;
}

.city-marker:hover circle { r: 14; }

.city-ring {
  fill: none;
  stroke-width: 2;
  opacity: 0;
  transition: opacity 0.3s;
}

.city-marker.in-route .city-ring { opacity: 1; }

.route-line {
  stroke: var(--gold);
  stroke-width: 2.5;
  fill: none;
  stroke-dasharray: 8 4;
  stroke-linecap: round;
  opacity: 0;
  transition: opacity 0.4s;
}

.route-line.active {
  opacity: 1;
  animation: dashMove 1.5s linear infinite;
}

@keyframes dashMove {
  to { stroke-dashoffset: -60; }
}

.route-arrow {
  fill: var(--gold);
  opacity: 0;
}

.route-arrow.active { opacity: 1; }

.map-hint {
  font-family: var(--font-data);
  font-size: 11px;
  color: rgba(240,244,255,0.35);
  text-align: center;
  margin-top: 12px;
  letter-spacing: 1px;
}

/* Map clear button */
.btn-clear-route {
  font-family: var(--font-data);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 6px 16px;
  background: transparent;
  border: 1px solid rgba(237,28,36,0.4);
  color: var(--red);
  border-radius: 3px;
  cursor: pointer;
  margin-top: 8px;
  transition: background 0.2s;
}

.btn-clear-route:hover { background: rgba(237,28,36,0.1); }

/* RIGHT PANEL */
.right-panel {
  background: var(--bg2);
  border-left: 1px solid rgba(0,120,215,0.2);
  overflow-y: auto;
  padding: 16px 12px;
}

/* METRICS */
.metric-block {
  background: var(--bg3);
  border: 1px solid rgba(0,120,215,0.15);
  border-radius: 6px;
  padding: 12px;
  margin-bottom: 10px;
}

.metric-header {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.metric-name {
  font-family: var(--font-data);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(240,244,255,0.5);
}

.metric-pts {
  font-family: var(--font-data);
  font-size: 11px;
  font-weight: 700;
  color: var(--gold);
}

.metric-bar-track {
  height: 6px;
  background: rgba(0,0,0,0.4);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 4px;
}

.metric-bar-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--blue), var(--blue2));
  transition: width 0.5s ease;
}

.metric-bar-fill.good { background: linear-gradient(90deg, var(--green), #1ba354); }
.metric-bar-fill.warn { background: linear-gradient(90deg, var(--gold), #d4981e); }
.metric-bar-fill.bad { background: linear-gradient(90deg, var(--red), #b01017); }

.metric-detail {
  font-family: var(--font-data);
  font-size: 10px;
  color: rgba(240,244,255,0.4);
}

/* FLEET STATUS */
.fleet-section {
  margin-bottom: 10px;
}

.fleet-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px;
  background: var(--bg3);
  border-radius: 5px;
  margin-bottom: 6px;
  border: 1px solid rgba(0,120,215,0.12);
}

.fleet-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--gray);
  flex-shrink: 0;
  transition: background 0.3s;
}

.fleet-dot.active { background: var(--green); box-shadow: 0 0 6px var(--green); }
.fleet-dot.in-route { background: var(--gold); }
.fleet-dot.conflict { background: var(--red); }

.fleet-city {
  font-family: var(--font-data);
  font-size: 11px;
  font-weight: 700;
  flex: 1;
}

.fleet-vehicle {
  font-family: var(--font-data);
  font-size: 10px;
  color: rgba(240,244,255,0.5);
}

/* SCORE PREVIEW */
.score-preview {
  background: rgba(247,183,49,0.07);
  border: 1px solid rgba(247,183,49,0.2);
  border-radius: 6px;
  padding: 14px;
  text-align: center;
  margin-bottom: 10px;
}

.score-big {
  font-family: var(--font-title);
  font-size: 56px;
  font-weight: 900;
  color: var(--gold);
  line-height: 1;
}

.score-max {
  font-family: var(--font-data);
  font-size: 11px;
  color: rgba(240,244,255,0.4);
  letter-spacing: 2px;
}

/* ── RESULT MODAL ── */
#result-modal {
  display: none;
  position: fixed; inset: 0; z-index: 500;
  background: rgba(7,11,20,0.92);
  backdrop-filter: blur(8px);
  overflow-y: auto;
  padding: 40px 20px;
}

.modal-inner {
  max-width: 720px;
  margin: 0 auto;
  background: var(--bg2);
  border: 1px solid rgba(0,120,215,0.3);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(0,120,215,0.2);
}

.modal-header {
  background: linear-gradient(135deg, var(--blue), #002d5c);
  padding: 28px 32px;
  display: flex; align-items: center; gap: 24px;
}

.score-circle-wrap {
  flex-shrink: 0;
}

.score-circle {
  width: 110px; height: 110px;
  position: relative;
}

.score-circle svg { transform: rotate(-90deg); }

.score-circle-number {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}

.score-circle-val {
  font-family: var(--font-title);
  font-size: 36px;
  font-weight: 900;
  color: var(--gold);
  line-height: 1;
}

.score-circle-label {
  font-family: var(--font-data);
  font-size: 9px;
  color: rgba(240,244,255,0.5);
  letter-spacing: 2px;
}

.modal-title-block {}

.modal-title {
  font-family: var(--font-title);
  font-size: 32px;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.modal-subtitle {
  font-size: 14px;
  color: rgba(240,244,255,0.6);
}

.modal-body { padding: 24px 32px; }

.modal-section-title {
  font-family: var(--font-title);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(240,244,255,0.4);
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(0,120,215,0.2);
}

/* Route comparison */
.route-comparison {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-bottom: 24px;
}

.route-col { }

.route-col-title {
  font-family: var(--font-data);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: var(--cyan);
}

.route-col-title.optimal { color: var(--green); }

.route-display {
  font-family: var(--font-data);
  font-size: 13px;
  line-height: 1.9;
  color: var(--gold);
}

.route-display.optimal { color: var(--green); }

/* Score breakdown */
.score-breakdown { margin-bottom: 24px; }

.breakdown-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0,120,215,0.1);
}

.breakdown-icon { font-size: 16px; width: 24px; text-align: center; }

.breakdown-name {
  font-size: 13px;
  flex: 1;
  color: rgba(240,244,255,0.8);
}

.breakdown-pts {
  font-family: var(--font-data);
  font-size: 14px;
  font-weight: 700;
  min-width: 60px;
  text-align: right;
}

.breakdown-pts.pos { color: var(--green); }
.breakdown-pts.neg { color: var(--red); }
.breakdown-pts.zero { color: rgba(240,244,255,0.3); }

.breakdown-bar {
  width: 80px;
  height: 4px;
  background: rgba(0,0,0,0.4);
  border-radius: 2px;
  overflow: hidden;
}

.breakdown-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--green);
}

/* Evaluator analysis */
.evaluator-card {
  background: var(--bg3);
  border: 1px solid rgba(72,219,251,0.2);
  border-radius: 6px;
  padding: 16px;
  margin-bottom: 20px;
}

.evaluator-title {
  font-family: var(--font-data);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--cyan);
  text-transform: uppercase;
  margin-bottom: 10px;
}

.evaluator-text {
  font-size: 14px;
  color: rgba(240,244,255,0.7);
  line-height: 1.7;
}

.modal-footer {
  padding: 20px 32px;
  border-top: 1px solid rgba(0,120,215,0.2);
  display: flex; justify-content: center; gap: 12px;
}

.btn-retry {
  font-family: var(--font-title);
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 12px 36px;
  background: linear-gradient(135deg, var(--blue), var(--blue2));
  border: none; border-radius: 4px;
  color: var(--white);
  cursor: pointer;
  transition: transform 0.2s;
}

.btn-retry:hover { transform: scale(1.04); }

/* Scrollbar styling */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0,120,215,0.3); border-radius: 10px; }

/* Notification toast */
.toast {
  position: fixed;
  bottom: 24px; right: 24px;
  background: var(--bg3);
  border: 1px solid var(--blue2);
  border-radius: 6px;
  padding: 12px 18px;
  font-family: var(--font-data);
  font-size: 12px;
  color: var(--white);
  z-index: 200;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.3s;
  max-width: 300px;
}

.toast.show { opacity: 1; transform: translateY(0); }
.toast.warn { border-color: var(--red); }
.toast.success { border-color: var(--green); }

/* Time expired overlay */
#time-expired {
  display: none;
  position: fixed; inset: 0; z-index: 300;
  background: rgba(7,11,20,0.85);
  align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}

.expired-msg {
  font-family: var(--font-title);
  font-size: 80px;
  font-weight: 900;
  color: var(--red);
  text-transform: uppercase;
  letter-spacing: 4px;
  text-align: center;
  animation: expiredPulse 0.5s ease infinite alternate;
}

@keyframes expiredPulse {
  from { opacity: 1; }
  to { opacity: 0.3; }
}

/* Responsive tweaks */
@media (max-width: 900px) {
  .main-grid { grid-template-columns: 1fr; }
  .center-panel, .right-panel { border: none; border-top: 1px solid rgba(0,120,215,0.2); }
}
</style>
</head>
