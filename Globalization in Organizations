<script>
// ══════════════════════════════════════
// CONSTANTS & DATA
// ══════════════════════════════════════

const CITIES = {
  GYE: { name: 'Guayaquil', units: 0,   cold: false, x4x4: false },
  UIO: { name: 'Quito',     units: 420,  cold: false, x4x4: false },
  MCH: { name: 'Machala',   units: 580,  cold: false, x4x4: false },
  CUE: { name: 'Cuenca',    units: 310,  cold: true,  x4x4: true  },
  MEC: { name: 'Manta',     units: 240,  cold: false, x4x4: false },
};

const DISTANCES = {
  'GYE-UIO':275,'GYE-MCH':88,'GYE-CUE':195,'GYE-MEC':200,
  'UIO-MCH':335,'UIO-CUE':240,'UIO-MEC':310,
  'MCH-CUE':170,'MCH-MEC':295,
  'CUE-MEC':360
};

function getDist(a, b) {
  const k1 = `${a}-${b}`, k2 = `${b}-${a}`;
  return DISTANCES[k1] || DISTANCES[k2] || 0;
}

const VEHICLES = [
  { id:'std',  icon:'🚚', name:'Estándar',     cap:900, cold:false, x4x4:false, speed:1.00 },
  { id:'ref',  icon:'🧊', name:'Refrigerado',  cap:700, cold:true,  x4x4:false, speed:0.92 },
  { id:'4x4',  icon:'🛻', name:'4x4 Terreno',  cap:600, cold:false, x4x4:true,  speed:0.88 },
  { id:'r4x4', icon:'❄🛻',name:'Refrig. 4x4',  cap:500, cold:true,  x4x4:true,  speed:0.82 },
];

const AVG_SPEED_KMH = 60; // base speed km/h

// ══════════════════════════════════════
// GAME STATE
// ══════════════════════════════════════

let gameState = {
  route: [],       // city codes in order (excludes GYE start/end)
  vehicles: {},    // { cityCode: vehicleId }
  timerSec: 300,
  timerInterval: null,
  startTime: null,
  submitted: false,
};

// ══════════════════════════════════════
// INTRO
// ══════════════════════════════════════

function buildStars() {
  const container = document.getElementById('stars-bg');
  for (let i = 0; i < 80; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 3 + 1;
    s.style.cssText = `
      left:${Math.random()*100}%;
      top:${Math.random()*100}%;
      width:${size}px;
      height:${size}px;
      --d:${2+Math.random()*4}s;
      --delay:${Math.random()*3}s;
    `;
    container.appendChild(s);
  }
}
buildStars();

function startGame() {
  document.getElementById('intro-screen').style.display = 'none';
  const gs = document.getElementById('game-screen');
  gs.style.display = 'flex';
  buildVehicleGrids();
  gameState.startTime = Date.now();
  startTimer();
}

// ══════════════════════════════════════
// VEHICLE GRIDS
// ══════════════════════════════════════

function buildVehicleGrids() {
  ['UIO','MCH','CUE','MEC'].forEach(city => {
    const grid = document.getElementById(`vgrid-${city}`);
    grid.innerHTML = '';
    VEHICLES.forEach(v => {
      const btn = document.createElement('div');
      btn.className = 'vehicle-btn';
      btn.id = `vbtn-${city}-${v.id}`;
      btn.innerHTML = `
        <div class="vehicle-icon">${v.icon}</div>
        <div class="vehicle-name">${v.name}</div>
        <div class="vehicle-cap">${v.cap} unid</div>
      `;
      btn.onclick = () => assignVehicle(city, v.id);
      grid.appendChild(btn);
    });
  });
}

function assignVehicle(city, vehicleId) {
  gameState.vehicles[city] = vehicleId;

  // Update visual selection
  ['UIO','MCH','CUE','MEC'].forEach(c => {
    if (c !== city) return;
    VEHICLES.forEach(v => {
      const btn = document.getElementById(`vbtn-${c}-${v.id}`);
      if (btn) {
        btn.classList.remove('selected','conflict');
        if (v.id === vehicleId) btn.classList.add('selected');
      }
    });
  });

  // Check conflict for CUE
  if (city === 'CUE') {
    const veh = VEHICLES.find(v => v.id === vehicleId);
    const ok = veh.cold && veh.x4x4;
    const btn = document.getElementById(`vbtn-CUE-${vehicleId}`);
    if (!ok && btn) {
      btn.classList.remove('selected');
      btn.classList.add('conflict');
    }
  }

  updateFleetStatus();
  updateCardStatus();
  updateMetrics();
  checkSubmitReady();
  showToast(`✓ ${CITIES[city].name}: ${VEHICLES.find(v=>v.id===vehicleId).icon} ${VEHICLES.find(v=>v.id===vehicleId).name}`, 'success');
}

// ══════════════════════════════════════
// ROUTE MANAGEMENT
// ══════════════════════════════════════

function toggleCity(code) {
  if (gameState.submitted) return;
  const idx = gameState.route.indexOf(code);
  if (idx === -1) {
    gameState.route.push(code);
    showToast(`+ ${CITIES[code].name} añadida a la ruta`);
    // Auto-open card
    const card = document.getElementById(`card-${code}`);
    if (card && !card.classList.contains('open')) {
      card.classList.add('open');
    }
  } else {
    gameState.route.splice(idx, 1);
    showToast(`− ${CITIES[code].name} removida de la ruta`, 'warn');
  }
  updateRouteVisuals();
  updateMetrics();
  checkSubmitReady();
}

function toggleCard(code) {
  const card = document.getElementById(`card-${code}`);
  if (!card) return;
  card.classList.toggle('open');
}

function clearRoute() {
  if (gameState.submitted) return;
  gameState.route = [];
  gameState.vehicles = {};
  // Reset all vehicle buttons
  ['UIO','MCH','CUE','MEC'].forEach(city => {
    VEHICLES.forEach(v => {
      const btn = document.getElementById(`vbtn-${city}-${v.id}`);
      if (btn) btn.classList.remove('selected','conflict');
    });
  });
  updateRouteVisuals();
  updateFleetStatus();
  updateCardStatus();
  updateMetrics();
  checkSubmitReady();
  showToast('Ruta limpiada', 'warn');
}

function updateRouteVisuals() {
  const destCodes = ['UIO','MCH','CUE','MEC'];

  // Update map markers
  destCodes.forEach(code => {
    const marker = document.getElementById(`marker-${code}`);
    const inRoute = gameState.route.includes(code);
    if (marker) {
      // Find the ring
      const ring = marker.querySelector('.city-ring');
      if (ring) ring.style.opacity = inRoute ? '1' : '0';
      // Inner circle color
      const circles = marker.querySelectorAll('circle');
      if (circles[1]) {
        circles[1].setAttribute('fill', inRoute ? (gameState.vehicles[code] ? 'var(--green)' : 'var(--gold)') : 'var(--bg3)');
      }
    }
  });

  // Draw route lines
  // Full route: GYE → r[0] → r[1] → ... → GYE
  const allLines = document.querySelectorAll('.route-line');
  allLines.forEach(l => l.classList.remove('active'));

  const fullRoute = ['GYE', ...gameState.route, 'GYE'];
  for (let i = 0; i < fullRoute.length - 1; i++) {
    const a = fullRoute[i], b = fullRoute[i+1];
    const lineId1 = `line-${a}-${b}`;
    const lineId2 = `line-${b}-${a}`;
    const line = document.getElementById(lineId1) || document.getElementById(lineId2);
    if (line) line.classList.add('active');
  }

  // Update route path display
  const pathEl = document.getElementById('route-path-display');
  const kmEl = document.getElementById('route-km-display');
  if (gameState.route.length === 0) {
    pathEl.textContent = 'GYE → …';
    kmEl.textContent = '0 km total';
  } else {
    pathEl.innerHTML = fullRoute.join(' →\n');
    const totalKm = calcTotalDistance();
    kmEl.textContent = `${totalKm} km total`;
  }
}

function calcTotalDistance() {
  const fullRoute = ['GYE', ...gameState.route, 'GYE'];
  let total = 0;
  for (let i = 0; i < fullRoute.length - 1; i++) {
    total += getDist(fullRoute[i], fullRoute[i+1]);
  }
  return total;
}

// Time to reach UIO in the route (hours)
function calcTimeToUIO() {
  if (!gameState.route.includes('UIO')) return null;
  const vehId = gameState.vehicles['UIO'];
  const veh = vehId ? VEHICLES.find(v => v.id === vehId) : null;
  const speedFactor = veh ? veh.speed : 1.0;
  const effectiveSpeed = AVG_SPEED_KMH * speedFactor;

  // Time from GYE along route until UIO
  const fullRoute = ['GYE', ...gameState.route];
  let dist = 0;
  for (let i = 0; i < fullRoute.length - 1; i++) {
    dist += getDist(fullRoute[i], fullRoute[i+1]);
    if (fullRoute[i+1] === 'UIO') break;
  }
  return dist / effectiveSpeed;
}

// Time to reach CUE
function calcTimeToCUE() {
  if (!gameState.route.includes('CUE')) return null;
  const vehId = gameState.vehicles['CUE'];
  const veh = vehId ? VEHICLES.find(v => v.id === vehId) : null;
  const speedFactor = veh ? veh.speed : 1.0;
  const effectiveSpeed = AVG_SPEED_KMH * speedFactor;

  const fullRoute = ['GYE', ...gameState.route];
  let dist = 0;
  for (let i = 0; i < fullRoute.length - 1; i++) {
    dist += getDist(fullRoute[i], fullRoute[i+1]);
    if (fullRoute[i+1] === 'CUE') break;
  }
  return dist / effectiveSpeed;
}

function calcTotalRouteTime() {
  const fullRoute = ['GYE', ...gameState.route, 'GYE'];
  let totalDist = 0;
  for (let i = 0; i < fullRoute.length - 1; i++) {
    totalDist += getDist(fullRoute[i], fullRoute[i+1]);
  }
  // Use average speed factor of assigned vehicles
  const assignedVehs = Object.values(gameState.vehicles).map(id => VEHICLES.find(v=>v.id===id)).filter(Boolean);
  const avgFactor = assignedVehs.length ? assignedVehs.reduce((s,v)=>s+v.speed,0)/assignedVehs.length : 1.0;
  return totalDist / (AVG_SPEED_KMH * avgFactor);
}

// ══════════════════════════════════════
// CARD & FLEET STATUS
// ══════════════════════════════════════

function updateCardStatus() {
  ['UIO','MCH','CUE','MEC'].forEach(code => {
    const card = document.getElementById(`card-${code}`);
    if (!card) return;
    card.classList.remove('in-route','assigned','conflict');
    const inRoute = gameState.route.includes(code);
    const hasVeh = !!gameState.vehicles[code];

    if (!inRoute) return;

    if (code === 'CUE' && hasVeh) {
      const veh = VEHICLES.find(v => v.id === gameState.vehicles[code]);
      const ok = veh && veh.cold && veh.x4x4;
      card.classList.add(ok ? 'assigned' : 'conflict');
    } else if (hasVeh) {
      const veh = VEHICLES.find(v => v.id === gameState.vehicles[code]);
      const ok = veh && veh.cap >= CITIES[code].units;
      card.classList.add(ok ? 'assigned' : 'conflict');
    } else if (inRoute) {
      card.classList.add('in-route');
    }
  });
}

function updateFleetStatus() {
  ['UIO','MCH','CUE','MEC'].forEach(code => {
    const dot = document.getElementById(`fdot-${code}`);
    const vehLabel = document.getElementById(`fveh-${code}`);
    if (!dot || !vehLabel) return;

    dot.className = 'fleet-dot';
    const vehId = gameState.vehicles[code];
    const inRoute = gameState.route.includes(code);

    if (!inRoute) {
      vehLabel.textContent = 'Sin ruta';
      return;
    }

    if (!vehId) {
      dot.classList.add('in-route');
      vehLabel.textContent = 'Sin vehículo';
      return;
    }

    const veh = VEHICLES.find(v => v.id === vehId);
    if (!veh) return;

    let ok = veh.cap >= CITIES[code].units;
    if (code === 'CUE') ok = ok && veh.cold && veh.x4x4;

    dot.classList.add(ok ? 'active' : 'conflict');
    vehLabel.textContent = `${veh.icon} ${veh.name}`;
  });
}

// ══════════════════════════════════════
// SCORING
// ══════════════════════════════════════

function computeScore() {
  const R = gameState.route;
  const V = gameState.vehicles;
  let scores = {};
  const OPTIMAL_KM = 756;

  // 1. Coverage (up to 200)
  const coverage = (R.length / 4) * 200;
  scores.coverage = Math.round(coverage);

  // 2. Distance efficiency (up to 150)
  let distScore = 0;
  if (R.length > 0) {
    const totalKm = calcTotalDistance();
    const ratio = OPTIMAL_KM / totalKm;
    distScore = Math.min(150, Math.round(150 * Math.min(ratio, 1.0)));
    if (totalKm < OPTIMAL_KM * 0.5) distScore = 0; // unrealistic
  }
  scores.distance = distScore;

  // 3. Cuenca vehicle (up to 150, penalty if wrong)
  let cueScore = 0;
  if (R.includes('CUE')) {
    const vehId = V['CUE'];
    if (vehId) {
      const veh = VEHICLES.find(v=>v.id===vehId);
      if (veh.cold && veh.x4x4) cueScore = 150;
      else if (veh.cold || veh.x4x4) cueScore = -50;
      else cueScore = -100;
    }
  }
  scores.cueVehicle = cueScore;

  // 4. UIO on time ≤4.5h (150 pts, -120 if late)
  let uioScore = 0;
  if (R.includes('UIO')) {
    const timeH = calcTimeToUIO();
    if (timeH !== null) {
      if (timeH <= 4.5) uioScore = 150;
      else uioScore = -120;
    }
  }
  scores.uioTime = uioScore;

  // 5. Capacity per city (up to 100, penalty if overloaded)
  let capScore = 0;
  let capPossible = 0;
  R.forEach(code => {
    capPossible += 25;
    const vehId = V[code];
    if (vehId) {
      const veh = VEHICLES.find(v=>v.id===vehId);
      if (veh.cap >= CITIES[code].units) capScore += 25;
      else capScore -= 10;
    }
  });
  scores.capacity = Math.round(capScore);

  // 6. CUE cold chain ≤5h (up to 100)
  let coldScore = 0;
  if (R.includes('CUE')) {
    const timeH = calcTimeToCUE();
    const vehId = V['CUE'];
    const veh = vehId ? VEHICLES.find(v=>v.id===vehId) : null;
    const hasCold = veh && veh.cold;
    if (timeH !== null && hasCold) {
      if (timeH <= 5) coldScore = 100;
      else coldScore = Math.round(100 * Math.max(0, 1 - (timeH-5)/5));
    }
  }
  scores.coldChain = coldScore;

  // 7. Total time ≤10h (up to 100)
  let timeScore = 0;
  if (R.length > 0) {
    const totalH = calcTotalRouteTime();
    if (totalH <= 10) timeScore = 100;
    else timeScore = Math.round(100 * Math.max(0, 1 - (totalH-10)/10));
  }
  scores.totalTime = timeScore;

  // 8. Speed bonus (<2 min from start)
  let speedBonus = 0;
  const elapsedSec = gameState.startTime ? (Date.now() - gameState.startTime) / 1000 : 999;
  if (R.length >= 3 && elapsedSec < 120) speedBonus = 50;
  scores.speedBonus = speedBonus;

  // Total
  const total = Math.max(0, Math.min(1000,
    scores.coverage + scores.distance + scores.cueVehicle +
    scores.uioTime + scores.capacity + scores.coldChain +
    scores.totalTime + scores.speedBonus
  ));
  scores.total = total;
  return scores;
}

// ══════════════════════════════════════
// LIVE METRICS UPDATE
// ══════════════════════════════════════

function updateMetrics() {
  const scores = computeScore();
  const R = gameState.route;
  const V = gameState.vehicles;

  // Coverage
  setMetric('coverage', scores.coverage, 200, `${R.length} / 4 destinos`);

  // Distance
  const km = calcTotalDistance();
  const distPct = km > 0 ? Math.round((756/km)*100) : 0;
  setMetric('distance', scores.distance, 150, km > 0 ? `${km} km · Óptimo: 756 km` : 'Añade ciudades');

  // CUE
  const cuePct = Math.max(0, scores.cueVehicle > 0 ? scores.cueVehicle : 0);
  const cueDetail = R.includes('CUE') ? (V['CUE'] ? (scores.cueVehicle > 0 ? '✓ Vehículo correcto' : '✗ Requiere frío+4x4') : 'Sin vehículo asignado') : 'Cuenca no en ruta';
  const cueBar = document.getElementById('m-cold-bar');
  const cuePts = document.getElementById('m-cold-pts');
  cueBar.style.width = `${Math.max(0, scores.cueVehicle/150*100)}%`;
  cueBar.className = `metric-bar-fill ${scores.cueVehicle >= 150 ? 'good' : scores.cueVehicle < 0 ? 'bad' : 'warn'}`;
  cuePts.textContent = `${scores.cueVehicle > 0 ? '+' : ''}${scores.cueVehicle} pts`;
  document.getElementById('m-cold-detail').textContent = cueDetail;

  // UIO time
  const uioH = calcTimeToUIO();
  const uioDetail = uioH !== null ? `Llegada en ${uioH.toFixed(1)}h (ventana ≤4.5h)` : R.includes('UIO') ? 'Asigna vehículo' : 'Quito no en ruta';
  const uioBar = document.getElementById('m-uio-bar');
  const uioPts = document.getElementById('m-uio-pts');
  uioBar.style.width = `${scores.uioTime > 0 ? 100 : (scores.uioTime < 0 ? 100 : 0)}%`;
  uioBar.className = `metric-bar-fill ${scores.uioTime >= 150 ? 'good' : scores.uioTime < 0 ? 'bad' : 'warn'}`;
  uioPts.textContent = `${scores.uioTime > 0 ? '+' : ''}${scores.uioTime} pts`;
  document.getElementById('m-uio-detail').textContent = uioDetail;

  // Capacity
  setMetric('capacity', Math.max(0, scores.capacity), 100, scores.capacity < 0 ? '✗ Sobrecarga detectada' : 'Capacidades OK');

  // Total time
  const totalH = R.length > 0 ? calcTotalRouteTime() : 0;
  setMetric('time', scores.totalTime, 100, totalH > 0 ? `${totalH.toFixed(1)}h total (meta ≤10h)` : 'Sin ruta calculada');

  // Live score
  const sv = document.getElementById('score-live');
  const sr = document.getElementById('score-right');
  sv.textContent = scores.total;
  if (sr) sr.textContent = scores.total;

  updateCardStatus();
}

function setMetric(id, val, max, detail) {
  const bar = document.getElementById(`m-${id}-bar`);
  const pts = document.getElementById(`m-${id}-pts`);
  const det = document.getElementById(`m-${id}-detail`);
  if (!bar || !pts) return;
  const pct = Math.max(0, Math.min(100, (val/max)*100));
  bar.style.width = `${pct}%`;
  bar.className = `metric-bar-fill ${pct >= 80 ? 'good' : pct >= 40 ? 'warn' : 'bad'}`;
  pts.textContent = `${val > 0 ? '+' : ''}${val} pts`;
  if (det) det.textContent = detail;
}

// ══════════════════════════════════════
// SUBMIT
// ══════════════════════════════════════

function checkSubmitReady() {
  const ready = gameState.route.length >= 3;
  document.getElementById('btn-submit').disabled = !ready;
}

function submitRoute() {
  if (gameState.submitted) return;
  gameState.submitted = true;
  clearInterval(gameState.timerInterval);
  showResultModal();
}

function forceSubmit() {
  document.getElementById('time-expired').style.display = 'none';
  gameState.submitted = true;
  showResultModal();
}

function showResultModal() {
  const scores = computeScore();
  const R = gameState.route;
  const V = gameState.vehicles;
  const modal = document.getElementById('result-modal');
  modal.style.display = 'block';

  // Score arc animation
  const arc = document.getElementById('score-arc');
  const circumference = 301.6;
  const offset = circumference - (scores.total / 1000) * circumference;
  setTimeout(() => {
    arc.style.transition = 'stroke-dashoffset 1.5s ease';
    arc.setAttribute('stroke-dashoffset', offset);
  }, 100);

  // Score value count-up
  const scoreEl = document.getElementById('modal-score-val');
  let current = 0;
  const target = scores.total;
  const step = Math.ceil(target / 60);
  const counter = setInterval(() => {
    current = Math.min(current + step, target);
    scoreEl.textContent = current;
    if (current >= target) clearInterval(counter);
  }, 16);

  // Title
  const titleEl = document.getElementById('modal-title');
  const subEl = document.getElementById('modal-subtitle');
  if (scores.total >= 800) {
    titleEl.textContent = '🏆 EXCELENTE LOGÍSTICA';
    subEl.textContent = 'Candidato fuerte para la pasantía — decisión estratégica sobresaliente';
  } else if (scores.total >= 600) {
    titleEl.textContent = '⚡ BUENA GESTIÓN';
    subEl.textContent = 'Sólido desempeño — hay margen de optimización';
  } else if (scores.total >= 400) {
    titleEl.textContent = '📦 EN DESARROLLO';
    subEl.textContent = 'Potencial detectado — revisar cadena de frío y tiempos';
  } else {
    titleEl.textContent = '📋 OPORTUNIDAD DE MEJORA';
    subEl.textContent = 'Áreas críticas de optimización identificadas';
  }

  // Your route
  const routeEl = document.getElementById('modal-your-route');
  if (R.length === 0) {
    routeEl.textContent = '(Sin ruta definida)';
  } else {
    const full = ['GYE', ...R, 'GYE'];
    routeEl.innerHTML = full.join(' →<br>');
    const km = calcTotalDistance();
    routeEl.innerHTML += `<br><span style="color:rgba(240,244,255,0.4);font-size:11px">${km} km</span>`;
  }

  // Breakdown
  const breakdown = document.getElementById('score-breakdown');
  const items = [
    { icon:'🏙', name:'Cobertura de Ciudades', pts: scores.coverage, max: 200 },
    { icon:'📏', name:'Eficiencia de Distancia', pts: scores.distance, max: 150 },
    { icon:'❄',  name:'Vehículo Correcto Cuenca', pts: scores.cueVehicle, max: 150 },
    { icon:'⚡', name:'Quito Llegada a Tiempo', pts: scores.uioTime, max: 150 },
    { icon:'🚛', name:'Capacidad Correcta', pts: scores.capacity, max: 100 },
    { icon:'🧊', name:'Cadena de Frío Cuenca', pts: scores.coldChain, max: 100 },
    { icon:'🕐', name:'Tiempo Total Ruta', pts: scores.totalTime, max: 100 },
    { icon:'⚡', name:'Bonus Decisión Rápida', pts: scores.speedBonus, max: 50 },
  ];

  breakdown.innerHTML = items.map(item => {
    const cls = item.pts > 0 ? 'pos' : item.pts < 0 ? 'neg' : 'zero';
    const barPct = Math.max(0, (item.pts / item.max) * 100);
    return `
      <div class="breakdown-item">
        <div class="breakdown-icon">${item.icon}</div>
        <div class="breakdown-name">${item.name}</div>
        <div class="breakdown-bar">
          <div class="breakdown-bar-fill" style="width:${barPct}%;background:${item.pts < 0 ? 'var(--red)' : 'var(--green)'}"></div>
        </div>
        <div class="breakdown-pts ${cls}">${item.pts > 0 ? '+' : ''}${item.pts}</div>
      </div>
    `;
  }).join('');

  // Evaluator analysis
  const evalEl = document.getElementById('evaluator-text');
  let evalText = '';
  const cueVeh = V['CUE'] ? VEHICLES.find(v=>v.id===V['CUE']) : null;
  const uioTime = calcTimeToUIO();
  const cueTime = calcTimeToCUE();

  if (!R.includes('CUE')) evalText += '⚠️ <strong>Cuenca omitida:</strong> La entrega refrigerada de Tropicana/Lipton requiere atención inmediata. ';
  else if (cueVeh && (!cueVeh.cold || !cueVeh.x4x4)) evalText += '❌ <strong>Error crítico Cuenca:</strong> Se asignó vehículo sin las capacidades requeridas (frío + 4x4). Producto en riesgo sanitario. ';
  else if (cueVeh && cueTime > 5) evalText += '⚠️ <strong>Cadena de frío Cuenca:</strong> El tiempo de llegada supera la ventana de 5h para productos refrigerados. ';
  else if (cueVeh) evalText += '✅ <strong>Cuenca correcta:</strong> Vehículo Refrigerado 4x4 asignado y dentro de ventana de cadena de frío. ';

  if (!R.includes('UIO')) evalText += '⚠️ <strong>Quito omitido:</strong> Entrega urgente no atendida — penalización máxima aplicada. ';
  else if (uioTime > 4.5) evalText += `❌ <strong>Quito tarde:</strong> Llegada estimada ${uioTime?.toFixed(1)}h supera ventana de 4.5h. -120 pts aplicados. `;
  else evalText += `✅ <strong>Quito a tiempo:</strong> Llegada en ${uioTime?.toFixed(1)}h dentro de ventana crítica. `;

  if (scores.total >= 750) {
    evalText += '🏆 <strong>Perfil logístico sólido.</strong> Demuestra comprensión de trade-offs entre velocidad, capacidad y requisitos técnicos. Candidato destacado.';
  } else if (scores.total >= 500) {
    evalText += '📊 <strong>Desempeño competente.</strong> Buena cobertura pero optimización de ruta y asignación de flota mejorable. Revisa prioridades URGENTE vs VOLUMEN.';
  } else {
    evalText += '📋 <strong>Área de desarrollo:</strong> Revisar matriz de distancias, restricciones de vehículos y ventanas de entrega antes del próximo intento.';
  }

  evalEl.innerHTML = evalText;
}

// ══════════════════════════════════════
// TIMER
// ══════════════════════════════════════

function startTimer() {
  const timerEl = document.getElementById('timer-display');
  gameState.timerInterval = setInterval(() => {
    gameState.timerSec--;
    if (gameState.timerSec <= 0) {
      clearInterval(gameState.timerInterval);
      timerEl.textContent = '00:00';
      if (!gameState.submitted) {
        document.getElementById('time-expired').style.display = 'flex';
      }
      return;
    }
    const m = Math.floor(gameState.timerSec / 60);
    const s = gameState.timerSec % 60;
    timerEl.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    if (gameState.timerSec <= 30) timerEl.classList.add('urgent');
    else timerEl.classList.remove('urgent');
  }, 1000);
}

// ══════════════════════════════════════
// TOAST
// ══════════════════════════════════════

let toastTimeout;
function showToast(msg, type='info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast show ${type}`;
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => t.classList.remove('show'), 2500);
}

// ══════════════════════════════════════
// RETRY
// ══════════════════════════════════════

function retryGame() {
  gameState = {
    route: [],
    vehicles: {},
    timerSec: 300,
    timerInterval: null,
    startTime: Date.now(),
    submitted: false,
  };

  document.getElementById('result-modal').style.display = 'none';
  document.getElementById('time-expired').style.display = 'none';
  document.getElementById('timer-display').textContent = '05:00';
  document.getElementById('timer-display').classList.remove('urgent');
  document.getElementById('btn-submit').disabled = true;

  // Reset all cards
  ['UIO','MCH','CUE','MEC'].forEach(code => {
    const card = document.getElementById(`card-${code}`);
    if (card) card.classList.remove('in-route','assigned','conflict','open');
    VEHICLES.forEach(v => {
      const btn = document.getElementById(`vbtn-${code}-${v.id}`);
      if (btn) btn.classList.remove('selected','conflict');
    });
  });

  updateRouteVisuals();
  updateFleetStatus();
  updateMetrics();
  startTimer();
}

// ── init score arc
document.addEventListener('DOMContentLoaded', () => {
  const arc = document.getElementById('score-arc');
  if (arc) arc.setAttribute('stroke-dashoffset', '301.6');
});
</script>
